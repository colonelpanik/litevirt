# Generated by litevirt firewall renderer — do not edit by hand.
# `nft -f -` consumes this file as an atomic ruleset replace.

table inet litevirt-fw {
    set trusted {
        type ipv4_addr
        flags interval
        elements = { 10.0.0.0/24, 10.0.1.0/24 }
    }

    chain forward {
        type filter hook forward priority filter; policy drop;
        ct state established,related accept
        ct state invalid drop
        jump cluster_default
        jump host_overrides
        jump nic_dispatch
    }

    chain cluster_default {
    }

    chain host_overrides {
    }

    chain nic_dispatch {
        iifname tap-vm1-0 jump nic_tap_vm1_0
        oifname tap-vm1-0 jump nic_tap_vm1_0
    }

    chain nic_tap_vm1_0 {
        # security group "web"
        oifname tap-vm1-0 tcp dport 80 ip saddr @trusted accept
        oifname tap-vm1-0 tcp dport 443 ip saddr @trusted accept
    }

}
