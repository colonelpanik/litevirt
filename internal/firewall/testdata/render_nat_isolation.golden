# Generated by litevirt firewall renderer — do not edit by hand.
# `nft -f -` consumes this file as an atomic ruleset replace.

table inet litevirt-fw {
    chain forward {
        type filter hook forward priority filter; policy accept;
        ct state established,related accept
        ct state invalid drop
        jump cluster_default
        jump host_overrides
        jump nic_dispatch
    }

    chain cluster_default {
    }

    chain host_overrides {
    }

    chain nic_dispatch {
    }

    chain postrouting {
        type nat hook postrouting priority srcnat; policy accept;
        oifname eth0 ip saddr 10.100.0.0/24 snat to 203.0.113.5
        ip saddr 10.0.1.0/24 oifname != br-mgd-a masquerade
        ip saddr 10.0.2.0/24 oifname != br-mgd-b masquerade
    }

    chain input {
        type filter hook input priority filter; policy accept;
        iifname br-iso-a ip protocol 112 accept
        iifname br-iso-a ip daddr 10.100.0.50 tcp dport 80 accept
        iifname br-iso-a ip daddr 10.100.0.50 tcp dport 443 accept
        iifname br-iso-a drop
        iifname br-iso-z drop
    }

}
