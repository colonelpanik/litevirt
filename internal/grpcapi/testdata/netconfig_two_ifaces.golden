version: 1
config:
  - type: physical
    name: eth0
    mac_address: "aa:bb:cc:dd:ee:05"
    subnets:
      - type: static
        address: 10.0.0.10/24
        gateway: 10.0.0.1
        dns_nameservers:
          - 1.1.1.1
  - type: physical
    name: eth1
    mac_address: "aa:bb:cc:dd:ee:06"
    subnets:
      - type: static6
        address: 2001:db8::30/64
        gateway: 2001:db8::1
