
global_defs {
    enable_script_security
    script_user root
}

vrrp_script chk_haproxy {
    script "/usr/bin/pgrep -f egress-haproxy.cfg"
    interval 2
    weight 2
    rise 2
    fall 3
}

vrrp_instance egress {
    state MASTER
    interface eth0
    virtual_router_id 44
    priority 100
    advert_int 1

    authentication {
        auth_type PASS
        auth_pass ecf4d74e
    }

    virtual_ipaddress {
        10.0.100.1/24
    }

    track_script {
        chk_haproxy
    }

    notify_master "/etc/litevirt/lb/egress-notify.sh MASTER"
    notify_backup "/etc/litevirt/lb/egress-notify.sh BACKUP"
    notify_fault  "/etc/litevirt/lb/egress-notify.sh FAULT"
}
