{
  "annotations": { "list": [] },
  "description": "litevirt cluster overview — total VMs, host pressure, replication health. Generated by Plan §2.4.",
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "stat",
      "title": "VMs per host",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {"expr": "litevirt_host_vm_count", "legendFormat": "{{host}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Host pressure (CPU / mem / disk / net)",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 18, "x": 6, "y": 0},
      "targets": [
        {"expr": "litevirt_host_pressure", "legendFormat": "{{host}} {{dim}}"}
      ]
    },
    {
      "type": "stat",
      "title": "Replication watermark lag (oldest peer)",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 4},
      "targets": [
        {"expr": "max(litevirt_mutation_log_rows) - min(litevirt_replication_min_watermark_seq)"}
      ]
    },
    {
      "type": "stat",
      "title": "Open file descriptors",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8},
      "targets": [
        {"expr": "litevirt_daemon_open_fds", "legendFormat": "{{host}}"}
      ]
    },
    {
      "type": "stat",
      "title": "Failover leader",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
      "targets": [
        {"expr": "litevirt_failover_leader", "legendFormat": "{{host}}"}
      ]
    },
    {
      "type": "stat",
      "title": "Fence failures (rate)",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8},
      "targets": [
        {"expr": "rate(litevirt_fence_failures_total[5m])", "legendFormat": "{{host}}"}
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["litevirt", "cluster"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "litevirt — Cluster Overview",
  "uid": "litevirt-cluster-overview",
  "version": 1
}
