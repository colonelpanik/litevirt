        {"expr": "rate(litevirt_vm_disk_read_bytes_total[1m])", "legendFormat": "{{vm}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk write bytes/s",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
